{
  "entities": {
    "Alert": {
      "title": "Alert",
      "description": "A hazard alert triggered by weather conditions or manual input.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "alert_msg_en": { "type": "string" },
        "alert_msg_bn": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["Early Warning", "Emergency Alert", "Evacuation Alert"] },
        "risk_level": { "type": "string", "enum": ["Low", "Medium", "High", "Extreme"] },
        "hazard_type": { "type": "string" },
        "location": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isAutoGenerated": { "type": "boolean" },
        "is_active": { "type": "boolean" },
        "active": { "type": "boolean" }
      },
      "required": ["alert_msg_en", "category", "risk_level", "timestamp"]
    },
    "Region": {
      "title": "Region",
      "description": "A geographical region in Bangladesh.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "risk_level": { "type": "string", "enum": ["Low", "Medium", "High", "Extreme"] },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "risk_level"]
    },
    "Shelter": {
      "title": "Shelter",
      "description": "An emergency shelter location.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "object" },
        "capacity": { "type": "number" },
        "occupancy": { "type": "number" },
        "status": { "type": "string", "enum": ["Open", "Full", "Closed"] }
      },
      "required": ["name", "location", "status"]
    },
    "SOSAlert": {
      "title": "SOSAlert",
      "description": "A user-triggered emergency SOS signal.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "location": { "type": "object" },
        "status": { "type": "string", "enum": ["Pending", "Responding", "Resolved"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "vulnerabilities": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["userId", "userName", "location", "status", "timestamp"]
    },
    "Volunteer": {
      "title": "Volunteer",
      "description": "A local community volunteer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "regionId": { "type": "string" },
        "specialty": { "type": "array", "items": { "type": "string" } },
        "isAvailable": { "type": "boolean" },
        "rating": { "type": "number" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone", "regionId", "isAvailable"]
    },
    "EmergencyContact": {
      "title": "EmergencyContact",
      "description": "An official emergency helpline or contact.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "number": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["Police", "Fire", "Ambulance", "Volunteer", "Local Authority"] }
      },
      "required": ["name", "number", "type"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback on alert accuracy and usefulness.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "alertId": { "type": "string" },
        "regionId": { "type": "string" },
        "accuracy": { "type": "number" },
        "usefulness": { "type": "number" },
        "comments": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["alertId", "accuracy", "usefulness", "timestamp"]
    },
    "FalseAlertReport": {
      "title": "FalseAlertReport",
      "description": "User report of a false alert for model recalibration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "alertId": { "type": "string" },
        "userId": { "type": "string" },
        "feedback": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["alertId", "feedback", "timestamp"]
    },
    "BMBData": {
      "title": "BMBData",
      "description": "Meteorological data from Bangladesh Meteorological Department.",
      "type": "object",
      "properties": {
        "districtId": { "type": "string" },
        "temperature": { "type": "number" },
        "rainfall": { "type": "number" },
        "humidity": { "type": "number" },
        "uploadedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["districtId", "temperature", "rainfall", "humidity", "uploadedBy", "timestamp"]
    },
    "BWDBData": {
      "title": "BWDBData",
      "description": "Water level data from Bangladesh Water Development Board.",
      "type": "object",
      "properties": {
        "districtId": { "type": "string" },
        "waterLevel": { "type": "number" },
        "uploadedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["districtId", "waterLevel", "uploadedBy", "timestamp"]
    },
    "FFWCData": {
      "title": "FFWCData",
      "description": "Flood forecasting data from Flood Forecasting and Warning Centre.",
      "type": "object",
      "properties": {
        "districtId": { "type": "string" },
        "forecastLevel": { "type": "number" },
        "uploadedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["districtId", "forecastLevel", "uploadedBy", "timestamp"]
    },
    "DAEData": {
      "title": "DAEData",
      "description": "Agricultural impact data from Department of Agricultural Extension.",
      "type": "object",
      "properties": {
        "districtId": { "type": "string" },
        "cropDamageRisk": { "type": "number" },
        "uploadedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["districtId", "cropDamageRisk", "uploadedBy", "timestamp"]
    },
    "CPPData": {
      "title": "CPPData",
      "description": "Cyclone preparedness data from Cyclone Preparedness Programme.",
      "type": "object",
      "properties": {
        "districtId": { "type": "string" },
        "volunteerReadiness": { "type": "number" },
        "uploadedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["districtId", "volunteerReadiness", "uploadedBy", "timestamp"]
    }
  },
  "firestore": {
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "Collection of all hazard alerts."
    },
    "/regions/{regionId}": {
      "schema": "Region",
      "description": "Collection of regional risk data."
    },
    "/shelters/{shelterId}": {
      "schema": "Shelter",
      "description": "Collection of emergency shelter locations."
    },
    "/sos_alerts/{sosId}": {
      "schema": "SOSAlert",
      "description": "Collection of active SOS signals."
    },
    "/volunteers/{volunteerId}": {
      "schema": "Volunteer",
      "description": "Collection of registered local volunteers."
    },
    "/emergency_contacts/{contactId}": {
      "schema": "EmergencyContact",
      "description": "Collection of official emergency contacts."
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "Collection of user feedback for ML model improvement."
    },
    "/false_alerts/{reportId}": {
      "schema": "FalseAlertReport",
      "description": "Collection of false alert reports for model recalibration."
    },
    "/bmb_uploads/{id}": {
      "schema": "BMBData",
      "description": "Meteorological telemetry."
    },
    "/bwdb_uploads/{id}": {
      "schema": "BWDBData",
      "description": "Water level telemetry."
    },
    "/ffwc_uploads/{id}": {
      "schema": "FFWCData",
      "description": "Flood forecasting telemetry."
    },
    "/dae_uploads/{id}": {
      "schema": "DAEData",
      "description": "Agricultural impact telemetry."
    },
    "/cpp_uploads/{id}": {
      "schema": "CPPData",
      "description": "Cyclone preparedness telemetry."
    }
  }
}
