rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: alerts
    // Fields:
    //   - alert_msg_en: string (required)
    //   - alert_msg_bn: string (optional)
    //   - description: string (optional)
    //   - category: string (required, enum: Early Warning, Emergency Alert, Evacuation Alert)
    //   - risk_level: string (required, enum: Low, Medium, High, Extreme)
    //   - hazard_type: string (optional)
    //   - location: string (optional)
    //   - timestamp: string (required)
    //   - isAutoGenerated: bool (optional)
    //   - active: bool (optional)
    //
    // Collection: regions
    // Fields:
    //   - name: string (required)
    //   - risk_level: string (required, enum: Low, Medium, High, Extreme)
    //   - lastUpdated: string (required)
    //
    // Collection: shelters
    // Fields:
    //   - name: string (required)
    //   - location: map (required, lat/lng)
    //   - capacity: number (optional)
    //   - occupancy: number (optional)
    //   - status: string (required, enum: Open, Full, Closed)
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - phone: string (optional)
    //   - role: string (required, enum: admin, user)
    //
    // Collection: sos_alerts
    // Fields:
    //   - userId: string (required)
    //   - userName: string (required)
    //   - location: map (required, lat/lng)
    //   - status: string (required, enum: Pending, Responding, Resolved)
    //   - timestamp: string (required)
    //
    // Collection: volunteers
    // Fields:
    //   - name: string (required)
    //   - phone: string (required)
    //   - regionId: string (required)
    //   - isAvailable: bool (required)
    //
    // Collection: emergency_contacts
    // Fields:
    //   - name: string (required)
    //   - number: string (required)
    //   - type: string (required)
    //
    // Collection: feedback
    // Fields:
    //   - alertId: string (required)
    //   - regionId: string (optional)
    //   - accuracy: number (required, 1-5)
    //   - usefulness: number (required, 1-5)
    //   - comments: string (optional)
    //   - userId: string (optional)
    //   - timestamp: string (required)
    //
    // Collection: false_alerts
    // Fields:
    //   - alertId: string (required)
    //   - userId: string (optional)
    //   - feedback: string (required)
    //   - timestamp: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "praptee0@gmail.com" && request.auth.token.email_verified == true)); // Default admin
    }

    function isValidAlert(data) {
      return data.alert_msg_en is string && data.alert_msg_en.size() > 0 && data.alert_msg_en.size() < 200 &&
             data.category in ['Early Warning', 'Emergency Alert', 'Evacuation Alert'] &&
             data.risk_level in ['Low', 'Medium', 'High', 'Extreme'] &&
             data.timestamp is string;
    }

    function isValidRegion(data) {
      return data.name is string && data.name.size() > 0 &&
             data.risk_level in ['Low', 'Medium', 'High', 'Extreme'] &&
             data.lastUpdated is string;
    }

    function isValidShelter(data) {
      return data.name is string && data.name.size() > 0 &&
             data.location is map &&
             data.status in ['Open', 'Full', 'Closed'];
    }

    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    function isValidSOS(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() > 0 &&
             data.location is map &&
             data.status in ['Pending', 'Responding', 'Resolved'] &&
             data.timestamp is string;
    }

    function isValidVolunteer(data) {
      return data.name is string && data.name.size() > 0 &&
             data.phone is string && data.phone.size() > 0 &&
             data.regionId is string &&
             data.isAvailable is bool;
    }

    function isValidContact(data) {
      return data.name is string && data.name.size() > 0 &&
             data.number is string && data.number.size() > 0 &&
             data.type in ['Police', 'Fire', 'Ambulance', 'Volunteer', 'Local Authority'];
    }

    function isValidFeedback(data) {
      return data.alertId is string &&
             data.accuracy is number && data.accuracy >= 1 && data.accuracy <= 5 &&
             data.usefulness is number && data.usefulness >= 1 && data.usefulness <= 5 &&
             (!('comments' in data) || (data.comments is string && data.comments.size() < 1000)) &&
             data.timestamp is string;
    }

    function isValidFalseAlertReport(data) {
      return data.alertId is string &&
             data.feedback is string && data.feedback.size() > 0 && data.feedback.size() < 1000 &&
             data.timestamp is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /alerts/{alertId} {
      allow read: if true; // Publicly readable for safety
      allow create, update, delete: if isAdmin();
    }

    match /regions/{regionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /shelters/{shelterId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /sos_alerts/{sosId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidSOS(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /volunteers/{volunteerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /emergency_contacts/{contactId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow read: if true; // Community needs to see ground reality
      allow create: if isValidFeedback(request.resource.data);
    }

    match /false_alerts/{reportId} {
      allow read: if isAdmin();
      allow create: if isValidFalseAlertReport(request.resource.data);
    }

    // Telemetry Uploads
    match /bmb_uploads/{id} {
      allow read: if true;
      allow create: if isAuthenticated();
    }
    match /bwdb_uploads/{id} {
      allow read: if true;
      allow create: if isAuthenticated();
    }
    match /ffwc_uploads/{id} {
      allow read: if true;
      allow create: if isAuthenticated();
    }
    match /dae_uploads/{id} {
      allow read: if true;
      allow create: if isAuthenticated();
    }
    match /cpp_uploads/{id} {
      allow read: if true;
      allow create: if isAuthenticated();
    }
  }
}
